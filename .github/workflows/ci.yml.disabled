name: CI

on:
  pull_request:
  push:
    branches:
      - main

jobs:
  validate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: 20
      - name: Syntax check
        run: npm run check
      - name: Unit tests
        run: npm test
      - name: Claude plugin validation
        run: |
          npm install -g @anthropic-ai/claude-code
          npm run validate
